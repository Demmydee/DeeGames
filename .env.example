# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Supabase Configuration
SUPABASE_URL="your-supabase-url"
# Use anon key for frontend (if applicable)
SUPABASE_ANON_KEY="your-supabase-anon-key"
# Use service role key for backend to bypass RLS
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key"

# Paystack Configuration
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."
PAYSTACK_BASE_URL="https://api.paystack.co"
PAYSTACK_CALLBACK_URL="http://localhost:3000/deposit/callback"
PAYSTACK_WEBHOOK_SECRET="wh_..."

# Daily.co Configuration
DAILY_API_KEY="your-daily-api-key"

# Wallet Configuration
MIN_DEPOSIT_AMOUNT=100
MAX_DEPOSIT_AMOUNT=1000000
MIN_WITHDRAWAL_AMOUNT=500
MAX_WITHDRAWAL_AMOUNT=500000
REQUIRE_KYC_FOR_WITHDRAWAL=false

# Backend Configuration
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3000"
